{
  "crons": [
    {
      "path": "/api/toast-sync?mode=daily",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/sync-marginedge?step=daily",
      "schedule": "0 3 * * *"
    }
  ],
  "headers": [
    {
      "source": "/((?!_next/static|_next/image|favicon.ico).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma", "value": "no-cache" },
        { "key": "Expires", "value": "0" }
      ]
    }
  ]
}
